# Database Configuration
DB_HOST=
DB_PORT=
DB_USER=
DB_DATABASE=
# Note: Password is usually not needed here if using a dedicated user, but included for completeness logic if needed by app
DB_PASSWORD=

# JWT Secret Key
JWT_SECRET_KEY=

# WebPush
WEBPUSH_PUBLIC_KEY=
WEBPUSH_PRIVATE_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

# Frontend URL (for CORS/Redirects)
FRONTEND_URL=http://localhost:5173

# Comma-separated proxy IPs/CIDRs allowed to supply X-Forwarded-For.
# Docker Compose defaults this to Docker's 172.16.0.0/12 private range.
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Optional comma-separated allowlist for Web Push service hosts.
# Defaults: fcm.googleapis.com, updates.push.services.mozilla.com,
# *.push.apple.com, *.notify.windows.com
WEBPUSH_ALLOWED_HOSTS=

# Init data
INIT_ROOT_USER=
INIT_EVENT_NAME=
INIT_EVENT_YEAR=
INIT_EVENT_SEASON=
INIT_EVENT_START_DATE=
INIT_EVENT_END_DATE=
